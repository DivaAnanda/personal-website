---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { validateRequest } from '../../../lib/auth';
import { getAllProjects, deleteProject } from '../../../lib/db';

// Auth check
const { isAuthenticated } = validateRequest(Astro.request);
if (!isAuthenticated) {
    return Astro.redirect('/admin/login');
}

let message = '';
let messageType = '';

// Handle POST request
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action') as string;
        
        if (action === 'delete') {
            const id = parseInt(formData.get('id') as string);
            deleteProject(id);
            message = 'Project deleted successfully!';
            messageType = 'success';
        }
    } catch (error) {
        message = 'An error occurred';
        messageType = 'error';
    }
}

// Get current data
const projects = getAllProjects();
---

<AdminLayout title="Projects">
    <div class="page-header flex justify-between items-start">
        <div>
            <h1 class="page-title">Projects</h1>
            <p class="page-description">Manage your portfolio projects.</p>
        </div>
        <a href="/admin/projects/new" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Project
        </a>
    </div>
    
    {message && (
        <div class={`alert ${messageType === 'success' ? 'alert-success' : 'alert-error'}`}>
            {message}
        </div>
    )}
    
    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.length === 0 ? (
            <div class="col-span-full card text-center py-12">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-slate-600 mb-4">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                <p class="text-slate-400 mb-4">No projects yet.</p>
                <a href="/admin/projects/new" class="btn btn-primary">
                    Add Your First Project
                </a>
            </div>
        ) : (
            projects.map((project: any) => (
                <div class="card group overflow-hidden">
                    <!-- Project Image -->
                    <div class="aspect-video bg-slate-800 rounded-lg mb-4 overflow-hidden relative">
                        {project.image_path ? (
                            <img 
                                src={project.image_path} 
                                alt={project.title}
                                class="w-full h-full object-cover"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                                <span class="text-slate-600 text-2xl font-bold uppercase">{project.title.charAt(0)}</span>
                            </div>
                        )}
                        {project.featured && (
                            <span class="absolute top-2 right-2 px-2 py-1 bg-blue-600 text-white text-xs font-bold rounded">
                                Featured
                            </span>
                        )}
                    </div>
                    
                    <!-- Project Info -->
                    <h3 class="text-lg font-bold text-white mb-2">{project.title}</h3>
                    <p class="text-slate-400 text-sm line-clamp-2 mb-3">{project.description}</p>
                    
                    <!-- Tech Tags -->
                    {project.tech && project.tech.length > 0 && (
                        <div class="flex flex-wrap gap-1 mb-4">
                            {project.tech.slice(0, 3).map((t: string) => (
                                <span class="text-xs font-mono text-blue-300">#{t}</span>
                            ))}
                            {project.tech.length > 3 && (
                                <span class="text-xs text-slate-500">+{project.tech.length - 3}</span>
                            )}
                        </div>
                    )}
                    
                    <!-- Actions -->
                    <div class="flex gap-2 mt-auto pt-4 border-t border-slate-800">
                        <a href={`/admin/projects/${project.id}`} class="btn btn-sm btn-secondary flex-1">
                            Edit
                        </a>
                        <a href={`/projects/${project.slug}`} target="_blank" class="btn btn-sm btn-secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                <polyline points="15 3 21 3 21 9"/>
                                <line x1="10" y1="14" x2="21" y2="3"/>
                            </svg>
                        </a>
                        <form method="POST" style="display: inline;">
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="id" value={project.id} />
                            <button 
                                type="submit" 
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Are you sure you want to delete this project?')"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 6h18"/>
                                    <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                    <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            ))
        )}
    </div>
</AdminLayout>
