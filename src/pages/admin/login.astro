---
import '../../styles/admin.css';

// Check if already logged in
import { validateRequest } from '../../lib/auth';

const { isAuthenticated } = await validateRequest(Astro.request);
if (isAuthenticated) {
    return Astro.redirect('/admin');
}

// Get error message from URL
const error = Astro.url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Admin Login | Diva Ananda</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-950 text-slate-200 font-sans min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md p-8">
        <!-- Logo -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-white">
                DIVA<span class="text-blue-500">.ADMIN</span>
            </h1>
            <p class="text-slate-400 mt-2">Sign in to manage your website</p>
        </div>
        
        <!-- Error Message -->
        {error && (
            <div class="alert alert-error mb-6">
                {error === 'invalid' ? 'Invalid email or password' : 'An error occurred'}
            </div>
        )}
        
        <!-- Login Form -->
        <form method="POST" action="/api/auth/login" class="card">
            <div class="space-y-6">
                <div>
                    <label for="email" class="form-label">Email</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required 
                        class="form-input"
                        placeholder="admin@example.com"
                        autocomplete="email"
                    />
                </div>
                
                <div>
                    <label for="password" class="form-label">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required 
                        class="form-input"
                        placeholder="••••••••"
                        autocomplete="current-password"
                    />
                </div>
                
                <button type="submit" class="btn btn-primary w-full">
                    Sign In
                </button>
            </div>
        </form>
        
        <!-- Back to Website -->
        <div class="text-center mt-6">
            <a href="/" class="text-slate-400 hover:text-blue-400 transition-colors text-sm">
                ← Back to website
            </a>
        </div>
    </div>
</body>
</html>
