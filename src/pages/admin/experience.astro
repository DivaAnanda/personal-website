---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { validateRequest } from '../../lib/auth';
import { getAllExperience, addExperience, deleteExperience, updateExperience } from '../../lib/db';

// Auth check
const { isAuthenticated } = validateRequest(Astro.request);
if (!isAuthenticated) {
    return Astro.redirect('/admin/login');
}

let message = '';
let messageType = '';
let editingId = null;
let editingData = null;

// Handle POST request
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action') as string;
        
        if (action === 'add' || action === 'update') {
            const data = {
                role: formData.get('role') as string,
                company: formData.get('company') as string,
                date_range: formData.get('date_range') as string,
                description: formData.get('description') as string,
                tech: (formData.get('tech') as string)?.split(',').map(t => t.trim()).filter(Boolean) || [],
                sort_order: parseInt(formData.get('sort_order') as string) || 0,
            };
            
            if (action === 'add') {
                addExperience(data);
                message = 'Experience added successfully!';
            } else {
                const id = parseInt(formData.get('id') as string);
                updateExperience(id, data);
                message = 'Experience updated successfully!';
            }
            messageType = 'success';
        } else if (action === 'delete') {
            const id = parseInt(formData.get('id') as string);
            deleteExperience(id);
            message = 'Experience deleted successfully!';
            messageType = 'success';
        } else if (action === 'edit') {
            editingId = parseInt(formData.get('id') as string);
        }
    } catch (error) {
        message = 'An error occurred';
        messageType = 'error';
    }
}

// Get current data
const experiences = getAllExperience();
if (editingId) {
    editingData = experiences.find((e: any) => e.id === editingId);
}
---

<AdminLayout title="Experience">
    <div class="page-header flex justify-between items-start">
        <div>
            <h1 class="page-title">Experience</h1>
            <p class="page-description">Manage your work experience and career history.</p>
        </div>
        <button onclick="document.getElementById('add-modal').classList.remove('hidden')" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Experience
        </button>
    </div>
    
    {message && (
        <div class={`alert ${messageType === 'success' ? 'alert-success' : 'alert-error'}`}>
            {message}
        </div>
    )}
    
    <!-- Experience List -->
    <div class="space-y-4">
        {experiences.length === 0 ? (
            <div class="card text-center py-12">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-slate-600 mb-4">
                    <rect width="20" height="14" x="2" y="7" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                <p class="text-slate-400 mb-4">No experience entries yet.</p>
                <button onclick="document.getElementById('add-modal').classList.remove('hidden')" class="btn btn-primary">
                    Add Your First Experience
                </button>
            </div>
        ) : (
            experiences.map((exp: any, index: number) => (
                <div class="card group">
                    <div class="flex justify-between items-start gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <span class="text-blue-400 font-mono text-sm">{exp.date_range}</span>
                            </div>
                            <h3 class="text-xl font-bold text-white">{exp.role}</h3>
                            <p class="text-slate-400 font-medium">{exp.company}</p>
                            {exp.description && (
                                <p class="text-slate-400 text-sm mt-2">{exp.description}</p>
                            )}
                            {exp.tech && exp.tech.length > 0 && (
                                <div class="flex flex-wrap gap-2 mt-3">
                                    {exp.tech.map((t: string) => (
                                        <span class="tag">{t}</span>
                                    ))}
                                </div>
                            )}
                        </div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button 
                                onclick={`openEditModal(${JSON.stringify(exp)})`}
                                class="btn btn-sm btn-secondary"
                            >
                                Edit
                            </button>
                            <form method="POST" style="display: inline;">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="id" value={exp.id} />
                                <button 
                                    type="submit" 
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this experience?')"
                                >
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            ))
        )}
    </div>
    
    <!-- Add Modal -->
    <div id="add-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-800 rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center">
                <h2 class="text-xl font-bold text-white">Add Experience</h2>
                <button onclick="document.getElementById('add-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <form method="POST" class="p-6">
                <input type="hidden" name="action" value="add" />
                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">Role / Position *</label>
                            <input type="text" name="role" required class="form-input" placeholder="Game Developer Intern" />
                        </div>
                        <div>
                            <label class="form-label">Company *</label>
                            <input type="text" name="company" required class="form-input" placeholder="PT. Example" />
                        </div>
                    </div>
                    <div>
                        <label class="form-label">Date Range *</label>
                        <input type="text" name="date_range" required class="form-input" placeholder="Jul 2025 - Sep 2025" />
                    </div>
                    <div>
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-textarea" rows="3" placeholder="What did you do in this role?"></textarea>
                    </div>
                    <div>
                        <label class="form-label">Technologies (comma-separated)</label>
                        <input type="text" name="tech" class="form-input" placeholder="Unity, Game Design, C#" />
                    </div>
                    <div>
                        <label class="form-label">Sort Order</label>
                        <input type="number" name="sort_order" class="form-input" value="0" />
                        <p class="text-xs text-slate-500 mt-1">Lower numbers appear first</p>
                    </div>
                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="btn btn-primary">Add Experience</button>
                        <button type="button" onclick="document.getElementById('add-modal').classList.add('hidden')" class="btn btn-secondary">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-800 rounded-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center">
                <h2 class="text-xl font-bold text-white">Edit Experience</h2>
                <button onclick="document.getElementById('edit-modal').classList.add('hidden')" class="text-slate-400 hover:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <form method="POST" class="p-6" id="edit-form">
                <input type="hidden" name="action" value="update" />
                <input type="hidden" name="id" id="edit-id" />
                <div class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">Role / Position *</label>
                            <input type="text" name="role" id="edit-role" required class="form-input" />
                        </div>
                        <div>
                            <label class="form-label">Company *</label>
                            <input type="text" name="company" id="edit-company" required class="form-input" />
                        </div>
                    </div>
                    <div>
                        <label class="form-label">Date Range *</label>
                        <input type="text" name="date_range" id="edit-date_range" required class="form-input" />
                    </div>
                    <div>
                        <label class="form-label">Description</label>
                        <textarea name="description" id="edit-description" class="form-textarea" rows="3"></textarea>
                    </div>
                    <div>
                        <label class="form-label">Technologies (comma-separated)</label>
                        <input type="text" name="tech" id="edit-tech" class="form-input" />
                    </div>
                    <div>
                        <label class="form-label">Sort Order</label>
                        <input type="number" name="sort_order" id="edit-sort_order" class="form-input" />
                    </div>
                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <button type="button" onclick="document.getElementById('edit-modal').classList.add('hidden')" class="btn btn-secondary">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</AdminLayout>

<script>
    function openEditModal(exp) {
        document.getElementById('edit-id').value = exp.id;
        document.getElementById('edit-role').value = exp.role;
        document.getElementById('edit-company').value = exp.company;
        document.getElementById('edit-date_range').value = exp.date_range;
        document.getElementById('edit-description').value = exp.description || '';
        document.getElementById('edit-tech').value = exp.tech ? exp.tech.join(', ') : '';
        document.getElementById('edit-sort_order').value = exp.sort_order || 0;
        document.getElementById('edit-modal').classList.remove('hidden');
    }
    
    // Make function available globally
    window.openEditModal = openEditModal;
</script>
