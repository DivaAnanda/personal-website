---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { validateRequest } from '../../lib/auth';
import { getAllFloatingLabels, addFloatingLabel, deleteFloatingLabel, updateFloatingLabel } from '../../lib/db';

// Auth check
const { isAuthenticated } = validateRequest(Astro.request);
if (!isAuthenticated) {
    return Astro.redirect('/admin/login');
}

let message = '';
let messageType = '';

// Handle POST request
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action') as string;
        
        if (action === 'add') {
            const label = formData.get('label') as string;
            if (label && label.trim()) {
                addFloatingLabel(label.trim());
                message = 'Floating label added successfully!';
                messageType = 'success';
            }
        } else if (action === 'delete') {
            const id = parseInt(formData.get('id') as string);
            deleteFloatingLabel(id);
            message = 'Floating label deleted successfully!';
            messageType = 'success';
        } else if (action === 'update') {
            const id = parseInt(formData.get('id') as string);
            const label = formData.get('label') as string;
            const sortOrder = parseInt(formData.get('sort_order') as string) || 0;
            if (label && label.trim()) {
                updateFloatingLabel(id, label.trim(), sortOrder);
                message = 'Floating label updated successfully!';
                messageType = 'success';
            }
        }
    } catch (error) {
        message = 'An error occurred';
        messageType = 'error';
    }
}

// Get current data
const floatingLabels = getAllFloatingLabels();
---

<AdminLayout title="Floating Labels">
    <div class="page-header">
        <h1 class="page-title">Floating Labels</h1>
        <p class="page-description">Manage the floating tech badges displayed around the profile image in the About section.</p>
    </div>
    
    {message && (
        <div class={`alert ${messageType === 'success' ? 'alert-success' : 'alert-error'}`}>
            {message}
        </div>
    )}
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Add New Label -->
        <div class="card">
            <h2 class="text-lg font-semibold text-white mb-4">Add New Badge</h2>
            <form method="POST">
                <input type="hidden" name="action" value="add" />
                <div class="space-y-4">
                    <div>
                        <label for="label" class="form-label">Badge Text</label>
                        <input 
                            type="text" 
                            id="label" 
                            name="label" 
                            required 
                            class="form-input"
                            placeholder="e.g., React, Unity, Game Dev"
                        />
                    </div>
                    <button type="submit" class="btn btn-primary w-full">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Add Badge
                    </button>
                </div>
            </form>
            
            <div class="mt-6 p-4 bg-blue-900/20 border border-blue-800/50 rounded-lg">
                <p class="text-blue-300 text-sm">
                    <strong>Tip:</strong> These badges float around the profile image in the About section. Position is randomized automatically.
                </p>
            </div>
        </div>
        
        <!-- Current Labels -->
        <div class="lg:col-span-2 card">
            <h2 class="text-lg font-semibold text-white mb-4">
                Current Badges ({floatingLabels.length})
            </h2>
            
            {floatingLabels.length === 0 ? (
                <p class="text-slate-400 text-center py-8">
                    No floating labels added yet. Add your first badge to get started!
                </p>
            ) : (
                <div class="space-y-2">
                    {floatingLabels.map((label: any, index: number) => (
                        <div class="flex items-center gap-4 p-3 bg-slate-800/50 rounded-lg group hover:bg-slate-800 transition-colors">
                            <span class="text-slate-500 text-sm font-mono w-8">{index + 1}</span>
                            <span class="px-3 py-1 bg-slate-950 border border-slate-700 text-blue-400 text-xs rounded font-mono">
                                {label.label}
                            </span>
                            <span class="flex-1"></span>
                            <form method="POST" class="flex gap-2">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="id" value={label.id} />
                                <button 
                                    type="submit" 
                                    class="text-red-400 hover:text-red-300 opacity-0 group-hover:opacity-100 transition-opacity"
                                    onclick="return confirm('Are you sure you want to delete this badge?')"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 6h18"/>
                                        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    ))}
                </div>
            )}
        </div>
    </div>
    
    <!-- Preview -->
    <div class="card mt-6">
        <h2 class="text-lg font-semibold text-white mb-4">Preview</h2>
        <div class="relative h-64 bg-slate-900/50 rounded-lg border border-slate-800 flex items-center justify-center">
            <!-- Mock Globe -->
            <div class="w-32 h-32 rounded-full bg-slate-800/50 border border-blue-500/30 flex items-center justify-center">
                <span class="text-slate-500 text-xs font-mono">Profile</span>
            </div>
            
            <!-- Floating Labels Preview -->
            {floatingLabels.slice(0, 8).map((label: any, index: number) => {
                const positions = [
                    { top: '15%', left: '10%' },
                    { top: '20%', right: '15%' },
                    { bottom: '25%', left: '12%' },
                    { bottom: '20%', right: '10%' },
                    { top: '45%', left: '5%' },
                    { top: '40%', right: '8%' },
                    { bottom: '45%', left: '8%' },
                    { bottom: '40%', right: '12%' },
                ];
                const pos = positions[index % positions.length];
                
                return (
                    <div 
                        class="absolute animate-pulse"
                        style={`${pos.top ? `top: ${pos.top};` : ''} ${pos.bottom ? `bottom: ${pos.bottom};` : ''} ${pos.left ? `left: ${pos.left};` : ''} ${pos.right ? `right: ${pos.right};` : ''}`}
                    >
                        <span class="px-3 py-1 bg-slate-950 border border-slate-700 text-blue-400 text-xs rounded font-mono shadow-xl">
                            {label.label}
                        </span>
                    </div>
                );
            })}
        </div>
    </div>
</AdminLayout>
