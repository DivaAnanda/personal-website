---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { validateRequest } from '../../lib/auth';
import { getAllStats, addStat, deleteStat, updateStat } from '../../lib/db';

// Auth check
const { isAuthenticated } = validateRequest(Astro.request);
if (!isAuthenticated) {
    return Astro.redirect('/admin/login');
}

let message = '';
let messageType = '';

// Handle POST request
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action') as string;
        
        if (action === 'add') {
            const label = formData.get('label') as string;
            const value = formData.get('value') as string;
            const sortOrder = parseInt(formData.get('sort_order') as string) || 0;
            if (label && value) {
                addStat(label.trim(), value.trim(), sortOrder);
                message = 'Stat added successfully!';
                messageType = 'success';
            }
        } else if (action === 'delete') {
            const id = parseInt(formData.get('id') as string);
            deleteStat(id);
            message = 'Stat deleted successfully!';
            messageType = 'success';
        } else if (action === 'update') {
            const id = parseInt(formData.get('id') as string);
            const label = formData.get('label') as string;
            const value = formData.get('value') as string;
            const sortOrder = parseInt(formData.get('sort_order') as string) || 0;
            if (label && value) {
                updateStat(id, label.trim(), value.trim(), sortOrder);
                message = 'Stat updated successfully!';
                messageType = 'success';
            }
        }
    } catch (error) {
        message = 'An error occurred';
        messageType = 'error';
    }
}

// Get current data
const stats = getAllStats();
---

<AdminLayout title="Stats">
    <div class="page-header">
        <h1 class="page-title">About Section Stats</h1>
        <p class="page-description">Manage the statistics displayed in your About section (e.g., "2+ Years Experience").</p>
    </div>
    
    {message && (
        <div class={`alert ${messageType === 'success' ? 'alert-success' : 'alert-error'}`}>
            {message}
        </div>
    )}
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Add New Stat -->
        <div class="card">
            <h2 class="text-lg font-semibold text-white mb-4">Add New Stat</h2>
            <form method="POST">
                <input type="hidden" name="action" value="add" />
                <div class="space-y-4">
                    <div>
                        <label for="value" class="form-label">Value *</label>
                        <input 
                            type="text" 
                            id="value" 
                            name="value" 
                            required 
                            class="form-input"
                            placeholder="e.g., 2+, 10+, 100%"
                        />
                    </div>
                    <div>
                        <label for="label" class="form-label">Label *</label>
                        <input 
                            type="text" 
                            id="label" 
                            name="label" 
                            required 
                            class="form-input"
                            placeholder="e.g., Years Learning, Projects"
                        />
                    </div>
                    <div>
                        <label for="sort_order" class="form-label">Sort Order</label>
                        <input 
                            type="number" 
                            id="sort_order" 
                            name="sort_order" 
                            class="form-input"
                            value="0"
                        />
                        <p class="text-xs text-slate-500 mt-1">Lower numbers appear first</p>
                    </div>
                    <button type="submit" class="btn btn-primary w-full">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                        Add Stat
                    </button>
                </div>
            </form>
        </div>
        
        <!-- Current Stats -->
        <div class="lg:col-span-2 card">
            <h2 class="text-lg font-semibold text-white mb-4">
                Current Stats ({stats.length})
            </h2>
            
            {stats.length === 0 ? (
                <p class="text-slate-400 text-center py-8">
                    No stats added yet. Add your first stat to get started!
                </p>
            ) : (
                <div class="space-y-4">
                    {stats.map((stat: any) => (
                        <div class="flex items-center gap-4 p-4 bg-slate-800/50 rounded-lg group hover:bg-slate-800 transition-colors">
                            <div class="flex-1">
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-white">{stat.value}</span>
                                    <span class="text-slate-400">{stat.label}</span>
                                </div>
                            </div>
                            <form method="POST" class="flex gap-2">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="id" value={stat.id} />
                                <button 
                                    type="submit" 
                                    class="text-red-400 hover:text-red-300 opacity-0 group-hover:opacity-100 transition-opacity"
                                    onclick="return confirm('Are you sure you want to delete this stat?')"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 6h18"/>
                                        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    ))}
                </div>
            )}
        </div>
    </div>
    
    <!-- Preview -->
    <div class="card mt-6">
        <h2 class="text-lg font-semibold text-white mb-4">Preview (About Section)</h2>
        <div class="bg-slate-900/50 p-6 rounded-lg border border-slate-800">
            <div class="grid grid-cols-2 gap-8">
                {stats.map((stat: any) => (
                    <div>
                        <h4 class="text-2xl md:text-3xl font-bold text-white mb-1">{stat.value}</h4>
                        <p class="text-xs md:text-sm text-slate-500 font-mono uppercase">{stat.label}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</AdminLayout>
