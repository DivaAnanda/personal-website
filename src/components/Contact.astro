---
import { getSiteData } from '../lib/data';

const data = await getSiteData();
---

<section id="contact" class="py-24 px-6 md:px-12 bg-gradient-to-b from-[#0a0a0a] to-[#0f172a]">
  <div class="max-w-4xl mx-auto">
    <div class="scroll-animate glass border border-slate-800 p-6 sm:p-8 md:p-12 rounded-2xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-blue-500 font-mono text-sm tracking-widest mb-4">// CONTACT</h2>
          <h3 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">LET'S CONNECT</h3>
          <p class="text-slate-400 mb-8 text-sm md:text-base">
            Open for internship opportunities, collaboration projects, or just a friendly chat about technology and game development.
          </p>
          
          <div class="space-y-4">
            <!-- Email -->
            <a 
              href={data.socials.email}
              class="flex items-center gap-4 text-slate-300 hover:text-white transition-colors group"
            >
              <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <span class="text-sm md:text-base break-all">{data.personal.email}</span>
            </a>
            
            <!-- LinkedIn -->
            <a 
              href={data.socials.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 text-slate-300 hover:text-white transition-colors group"
            >
              <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect width="4" height="12" x="2" y="9"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </div>
              <span class="text-sm md:text-base">LinkedIn Profile</span>
            </a>

            <!-- GitHub -->
            <a 
              href={data.socials.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 text-slate-300 hover:text-white transition-colors group"
            >
              <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                  <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
              </div>
              <span class="text-sm md:text-base">GitHub Profile</span>
            </a>

            <!-- Instagram -->
            <a 
              href="https://www.instagram.com/divaa_anandaa/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 text-slate-300 hover:text-white transition-colors group"
            >
              <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
              </div>
              <span class="text-sm md:text-base">Instagram</span>
            </a>

            <!-- Location -->
            <div class="flex items-center gap-4 text-slate-400">
              <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <span class="text-sm md:text-base">{data.personal.location}</span>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <form class="space-y-4 w-full" id="contact-form">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-xs font-mono text-slate-400 uppercase" for="name">Name</label>
              <input 
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-slate-900 border border-slate-800 p-3 text-slate-200 focus:border-blue-500 outline-none transition-colors rounded-sm text-sm"
                placeholder="Your name"
              />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-mono text-slate-400 uppercase" for="email">Email</label>
              <input 
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-slate-900 border border-slate-800 p-3 text-slate-200 focus:border-blue-500 outline-none transition-colors rounded-sm text-sm"
                placeholder="your@email.com"
              />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-mono text-slate-400 uppercase" for="message">Message</label>
            <textarea 
              id="message"
              name="message"
              rows="5"
              required
              class="w-full bg-slate-900 border border-slate-800 p-3 text-slate-200 focus:border-blue-500 outline-none transition-colors rounded-sm resize-none text-sm"
              placeholder="Tell me about your project or idea..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full sm:w-auto px-8 py-3 bg-white text-slate-950 hover:bg-blue-400 hover:text-white font-bold tracking-wider transition-all duration-300 flex items-center justify-center gap-2 rounded-sm"
          >
            SEND MESSAGE
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Simple form handling - opens email client
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    const name = formData.get('name');
    const email = formData.get('email');
    const message = formData.get('message');
    
    const mailtoLink = `mailto:gedesuryadiva@gmail.com?subject=Contact from ${name}&body=${encodeURIComponent(`From: ${name}\nEmail: ${email}\n\nMessage:\n${message}`)}`;
    window.location.href = mailtoLink;
  });
</script>
