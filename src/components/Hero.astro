---
import { getSiteData } from '../lib/data';
const data = await getSiteData();
---

<section id="home" class="relative min-h-screen grid grid-cols-1 lg:grid-cols-2 gap-12 items-center px-6 md:px-20 pb-24 lg:pb-0 overflow-hidden bg-[#0a0a0a]">
  <!-- Background Grid Pattern -->
  <div class="absolute inset-0 z-0 bg-grid"></div>

  <!-- Spotlight Effect Layer (mouse-following) -->
  <div id="spotlight" class="pointer-events-none absolute inset-0 z-10 transition-opacity duration-300"></div>

  <!-- Content - Left Column -->
  <div class="relative z-20 max-w-5xl order-2 lg:order-1 pt-20 lg:pt-0">
    <div class="animate-fade-in-up">
      <span class="text-blue-500 font-mono tracking-widest text-sm md:text-base mb-4 block">
        // INTRODUCTION
      </span>
      <h1 class="font-display text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold text-slate-100 leading-tight tracking-tighter mb-6 uppercase">
        {(() => {
          const parts = data.personal.name.split(' ');
          return parts.length > 2 ? parts.slice(-2).join(' ') : data.personal.name;
        })()} <br />
        <span class="gradient-text">
          {data.personal.role.toUpperCase()}
        </span>
      </h1>
      <p class="text-slate-400 text-lg md:text-xl max-w-2xl leading-relaxed mb-10">
        {data.personal.tagline}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a 
          href="#projects"
          class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-none font-bold tracking-wider transition-all duration-300 flex items-center justify-center gap-2 group"
        >
          VIEW PROJECTS
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
        <a 
          href="#contact"
          class="px-8 py-4 border border-slate-700 hover:border-blue-500 text-slate-300 hover:text-blue-400 bg-transparent rounded-none font-bold tracking-wider transition-all duration-300 text-center"
        >
          CONTACT ME
        </a>
      </div>
    </div>
  </div>

  <!-- Hero Visual - Right Column: 3D System Core -->
  <div class="relative z-20 order-1 lg:order-2 flex justify-center items-center h-[400px] md:h-[500px] pt-28 lg:pt-0 overflow-visible">
    
    <!-- Central Core -->
    <div class="relative w-32 h-32 md:w-40 md:h-40 flex items-center justify-center z-20 animate-pulse-glow rounded-full">
      <!-- Core Glow -->
      <div class="absolute inset-0 bg-blue-500/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute inset-0 border-2 border-blue-400/30 rounded-full"></div>
      
      <!-- Core Geometry - Arc Reactor Icon (Circular) -->
      <div class="core-geometry w-20 h-20 bg-slate-900 border border-blue-500 rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(59,130,246,0.5)] z-20 relative">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400">
          <circle cx="12" cy="12" r="9" />
          <circle cx="12" cy="12" r="4" />
          <path d="M12 3v2" />
          <path d="M12 19v2" />
          <path d="M3 12h2" />
          <path d="M19 12h2" />
          <path d="M5.6 5.6l1.4 1.4" />
          <path d="M17 17l1.4 1.4" />
          <path d="M18.4 5.6l-1.4 1.4" />
          <path d="M7 17l-1.4 1.4" />
        </svg>
        <!-- Inner Core Glow -->
        <div class="absolute inset-0 bg-blue-500/30 rounded-full blur-md -z-10"></div>
      </div>
      
      <!-- Gyroscopic Rings -->
      <div class="absolute inset-[-20px] border border-slate-700/60 rounded-full z-10 animate-rotate-slow"></div>
      <div class="absolute inset-[-40px] border border-slate-700/40 rounded-full z-10 animate-rotate-reverse"></div>
      <div class="absolute inset-[-60px] border border-slate-800/80 rounded-full border-dashed z-10 animate-rotate-slow" style="animation-duration: 25s;"></div>
    </div>

    <!-- Orbiting Tech Elements (3D Effect) -->
    <!-- Orbit 1: Development -->
    <div class="orbital-3d" style="--delay: 0s; --radius: 140px; --speed: 8s;">
      <div class="orbital-content group">
        <div class="orbital-icon group-hover:border-blue-500 group-hover:text-blue-400 group-hover:scale-110 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <span class="orbital-tooltip">Development</span>
      </div>
    </div>
    
    <!-- Orbit 2: Database -->
    <div class="orbital-3d" style="--delay: -2s; --radius: 140px; --speed: 8s;">
      <div class="orbital-content group">
        <div class="orbital-icon group-hover:border-blue-500 group-hover:text-blue-400 group-hover:scale-110 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5V19A9 3 0 0 0 21 19V5"/>
            <path d="M3 12A9 3 0 0 0 21 12"/>
          </svg>
        </div>
        <span class="orbital-tooltip">Database</span>
      </div>
    </div>
    
    <!-- Orbit 3: Server -->
    <div class="orbital-3d" style="--delay: -4s; --radius: 140px; --speed: 8s;">
      <div class="orbital-content group">
        <div class="orbital-icon group-hover:border-blue-500 group-hover:text-blue-400 group-hover:scale-110 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
             <rect width="20" height="8" x="2" y="2" rx="2" ry="2"/>
            <rect width="20" height="8" x="2" y="14" rx="2" ry="2"/>
            <line x1="6" x2="6.01" y1="6" y2="6"/>
            <line x1="6" x2="6.01" y1="18" y2="18"/>
          </svg>
        </div>
        <span class="orbital-tooltip">Server</span>
      </div>
    </div>
    
    <!-- Orbit 4: Frontend (Counter-rotate) -->
    <div class="orbital-3d-reverse" style="--delay: -1s; --radius: 180px; --speed: 12s;">
      <div class="orbital-content group">
        <div class="orbital-icon group-hover:border-blue-500 group-hover:text-blue-400 group-hover:scale-110 transition-all duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2"/>
            <path d="M3 9h18"/>
            <path d="M9 21V9"/>
          </svg>
        </div>
        <span class="orbital-tooltip">Frontend</span>
      </div>
    </div>
    
    <!-- Orbit 5: Optimization (Counter-rotate) -->
    <div class="orbital-3d-reverse" style="--delay: -7s; --radius: 180px; --speed: 12s;">
      <div class="orbital-content group">
        <div class="orbital-icon group-hover:border-blue-500 group-hover:text-blue-400 group-hover:scale-110 transition-all duration-300">
           <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <span class="orbital-tooltip">Optimization</span>
      </div>
    </div>

    <!-- Data streams (decorative lines) -->
    <div class="absolute inset-0 pointer-events-none hidden lg:block">
      <div class="absolute top-1/2 left-1/2 w-[400px] h-[1px] bg-gradient-to-r from-transparent via-blue-900/50 to-transparent -translate-x-1/2 -translate-y-1/2 rotate-45"></div>
      <div class="absolute top-1/2 left-1/2 w-[400px] h-[1px] bg-gradient-to-r from-transparent via-blue-900/50 to-transparent -translate-x-1/2 -translate-y-1/2 -rotate-45"></div>
    </div>
  </div>

  <!-- Floating Keywords (Decorations) -->
  <div class="absolute right-10 bottom-20 hidden lg:block text-right opacity-20 pointer-events-none font-mono text-sm">
    <p>System.Architecture</p>
    <p>UX.Engineering</p>
    <p>Performance.Optimization</p>
  </div>
</section>

<style>
  /* 3D Core Rotation */
  .core-geometry {
    animation: core-rotate 20s linear infinite;
    transform-style: preserve-3d;
  }
  
  @keyframes core-rotate {
    from { transform: rotateY(0deg) rotateX(0deg); }
    to { transform: rotateY(360deg) rotateX(180deg); }
  }

  /* 3D Orbitals Logic */
  .orbital-3d, .orbital-3d-reverse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 48px;
    height: 48px;
    margin-left: -24px;
    margin-top: -24px;
    perspective: 1000px;
    will-change: transform, opacity, filter;
  }

  .orbital-3d {
    animation: orbit3D var(--speed) linear infinite;
    animation-delay: var(--delay);
  }

  /* Reverse orbit is just temporal offset or reversed direction, but here we can just use the same keyframes with negative speed or simpler: create a reverse keyframe set if needed, or just rely on different start/speeds. 
     Actually, typically reverse orbit just means going the other way. 
     Below orbit3D goes Counter-Clockwise (if we map math correctly).
     To go Clockwise, we can just Negate the X values? Or flip timing.
     Let's define orbit3D-reverse explicitly for clarity.
  */

  .orbital-3d-reverse {
    animation: orbit3D-reverse var(--speed) linear infinite;
    animation-delay: var(--delay);
  }

  /* 
    Mathematically generated Keyframes for Smooth Elliptical Orbit
    Formula:
    angle = 0 to 360
    radius = var(--radius)
    tilt = 0.2 (Y axis factor)
    
    X = radius * cos(a)
    Z = radius * sin(a)  (Depth)
    Y = Z * tilt = radius * sin(a) * 0.2
    
    Scale: 0.6 (at Z=-r) to 1.2 (at Z=+r)
    Base Scale = 0.9 + 0.3 * sin(a)
    
    Opacity: 0.3 to 1
    Blur: 4px to 0px
  */

  @keyframes orbit3D {
  0.0% { transform: translate3d(calc(var(--radius) * 1.000), calc(var(--radius) * 0.000), 0) scale(0.90); z-index: 20; opacity: 1.00; filter: blur(0.2px); }
  2.5% { transform: translate3d(calc(var(--radius) * 0.988), calc(var(--radius) * 0.063), 0) scale(0.95); z-index: 30; opacity: 1.00; filter: blur(0.0px); }
  5.0% { transform: translate3d(calc(var(--radius) * 0.951), calc(var(--radius) * 0.124), 0) scale(0.99); z-index: 30; opacity: 1.00; filter: blur(0.0px); }
  7.5% { transform: translate3d(calc(var(--radius) * 0.891), calc(var(--radius) * 0.182), 0) scale(1.04); z-index: 30; opacity: 1.00; filter: blur(0.0px); }
  10.0% { transform: translate3d(calc(var(--radius) * 0.809), calc(var(--radius) * 0.235), 0) scale(1.08); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  12.5% { transform: translate3d(calc(var(--radius) * 0.707), calc(var(--radius) * 0.283), 0) scale(1.11); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  15.0% { transform: translate3d(calc(var(--radius) * 0.588), calc(var(--radius) * 0.324), 0) scale(1.14); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  17.5% { transform: translate3d(calc(var(--radius) * 0.454), calc(var(--radius) * 0.356), 0) scale(1.17); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  20.0% { transform: translate3d(calc(var(--radius) * 0.309), calc(var(--radius) * 0.380), 0) scale(1.19); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  22.5% { transform: translate3d(calc(var(--radius) * 0.156), calc(var(--radius) * 0.395), 0) scale(1.20); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  25.0% { transform: translate3d(calc(var(--radius) * 0.000), calc(var(--radius) * 0.400), 0) scale(1.20); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  27.5% { transform: translate3d(calc(var(--radius) * -0.156), calc(var(--radius) * 0.395), 0) scale(1.20); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  30.0% { transform: translate3d(calc(var(--radius) * -0.309), calc(var(--radius) * 0.380), 0) scale(1.19); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
  32.5% { transform: translate3d(calc(var(--radius) * -0.454), calc(var(--radius) * 0.356), 0) scale(1.17); z-index: 40; opacity: 1.00; filter: blur(0.0px); }
