  }

  @keyframes orbit3D-reverse {
  0.0% { transform: translate3d(calc(var(--radius) * 1.000), calc(var(--radius) * -0.000), 0) scale(0.90); z-index: 10; opacity: 1.00; filter: blur(0.0px); }
