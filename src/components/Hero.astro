  67.5% { transform: translate3d(calc(var(--radius) * -0.454), calc(var(--radius) * -0.356), 0) scale(0.63); z-index: 5; opacity: 0.52; filter: blur(2.7px); }
  70.0% { transform: translate3d(calc(var(--radius) * -0.309), calc(var(--radius) * -0.380), 0) scale(0.61); z-index: 5; opacity: 0.51; filter: blur(2.9px); }
  72.5% { transform: translate3d(calc(var(--radius) * -0.156), calc(var(--radius) * -0.395), 0) scale(0.60); z-index: 5; opacity: 0.50; filter: blur(3.0px); }
  75.0% { transform: translate3d(calc(var(--radius) * 0.000), calc(var(--radius) * -0.400), 0) scale(0.60); z-index: 5; opacity: 0.50; filter: blur(3.0px); }
