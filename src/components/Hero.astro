  90.0% { transform: translate3d(calc(var(--radius) * 0.809), calc(var(--radius) * -0.235), 0) scale(0.72); z-index: 5; opacity: 0.58; filter: blur(1.8px); }
  92.5% { transform: translate3d(calc(var(--radius) * 0.891), calc(var(--radius) * -0.182), 0) scale(0.76); z-index: 10; opacity: 0.61; filter: blur(1.4px); }
  95.0% { transform: translate3d(calc(var(--radius) * 0.951), calc(var(--radius) * -0.124), 0) scale(0.81); z-index: 10; opacity: 0.64; filter: blur(0.9px); }
  97.5% { transform: translate3d(calc(var(--radius) * 0.988), calc(var(--radius) * -0.063), 0) scale(0.85); z-index: 10; opacity: 1.00; filter: blur(0.5px); }
