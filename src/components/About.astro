---
import { getSiteData } from '../lib/data';

const data = await getSiteData();
---

<section id="about" class="py-24 px-6 md:px-12 max-w-7xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Left Column - Text Content -->
    <div class="scroll-animate">
      <h2 class="text-blue-500 font-mono text-sm tracking-widest mb-4">// ABOUT_ME</h2>
      <h3 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-6 leading-tight">
        ENGINEERING THE FUTURE <br />OF DIGITAL PRODUCTS.
      </h3>
      <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-6">
        {data.personal.about}
      </p>

      <!-- Stats Grid (Dynamic from CMS) -->
      <div class="grid grid-cols-2 gap-8 mt-8">
        {data.stats.map((stat: any) => (
          <div>
            <h4 class="text-2xl md:text-3xl font-bold text-white mb-1">{stat.value}</h4>
            <p class="text-xs md:text-sm text-slate-500 font-mono uppercase">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Right Column - Profile Image with Wireframe Globe -->
    <div class="relative h-[400px] w-full flex items-center justify-center group scroll-animate">
      <!-- 3D Wireframe Sphere Background -->
      <div class="absolute inset-0 z-0">
        <canvas id="wireframe-globe" class="w-full h-full block"></canvas>
      </div>

      <!-- Central Card / Profile Image -->
      <div class="relative z-10 w-48 h-48 bg-slate-900/80 backdrop-blur-md border border-blue-500/30 rounded-full flex items-center justify-center shadow-[0_0_40px_rgba(59,130,246,0.2)] group-hover:scale-105 transition-transform duration-500 overflow-hidden">
        <img 
          src="/profile.png" 
          alt={data.personal.name}
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <!-- Fallback if no image -->
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/90 opacity-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 mb-2">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span class="text-xs font-mono text-blue-400 tracking-widest">PROFILE_IMG</span>
        </div>
      </div>

      <!-- Floating Tech Chips (Dynamic from CMS with random positions) -->
      {data.floatingLabels && data.floatingLabels.map((label: string, index: number) => {
        // Predefined positions that look good around the globe
        const positions = [
          { top: '10%', left: '5%' },
          { top: '15%', right: '5%' },
          { bottom: '20%', left: '8%' },
          { bottom: '15%', right: '10%' },
          { top: '40%', left: '0%' },
          { top: '35%', right: '0%' },
          { bottom: '40%', left: '3%' },
          { bottom: '35%', right: '5%' },
        ];
        const pos = positions[index % positions.length];
        const animDelay = index * 0.5;
        
        return (
          <div 
            class="absolute hidden md:block animate-float"
            style={`${pos.top ? `top: ${pos.top};` : ''} ${pos.bottom ? `bottom: ${pos.bottom};` : ''} ${pos.left ? `left: ${pos.left};` : ''} ${pos.right ? `right: ${pos.right};` : ''} --anim-delay: ${animDelay}s;`}
          >
            <span class="px-3 py-1 bg-slate-950 border border-slate-800 text-blue-400 text-xs rounded font-mono shadow-xl">
              {label}
            </span>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Wireframe Globe Animation
  const canvas = document.getElementById('wireframe-globe') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let width = canvas.width = canvas.offsetWidth;
      let height = canvas.height = canvas.offsetHeight;

      const handleResize = () => {
        if (canvas.parentElement) {
          width = canvas.width = canvas.parentElement.offsetWidth;
          height = canvas.height = canvas.parentElement.offsetHeight;
        }
      };

      handleResize();
      window.addEventListener('resize', handleResize);

      let time = 0;
      const dots: {x: number, y: number, z: number}[] = [];
      const NUM_DOTS = 50;

      for (let i = 0; i < NUM_DOTS; i++) {
        const phi = Math.acos(-1 + (2 * i) / NUM_DOTS);
        const theta = Math.sqrt(NUM_DOTS * Math.PI) * phi;
        dots.push({
          x: Math.cos(theta) * Math.sin(phi),
          y: Math.sin(theta) * Math.sin(phi),
          z: Math.cos(phi)
        });
      }

      let animationId: number;

      const animate = () => {
        time += 0.005;
        ctx.clearRect(0, 0, width, height);

        const currentRadius = Math.min(width, height) * 0.35;

        const projected = dots.map(dot => {
          const dx = dot.x * currentRadius;
          const dy = dot.y * currentRadius;
          const dz = dot.z * currentRadius;

          let x = dx * Math.cos(time) - dz * Math.sin(time);
          let z = dx * Math.sin(time) + dz * Math.cos(time);
          let y = dy * Math.cos(time * 0.5) - z * Math.sin(time * 0.5);
          z = dy * Math.sin(time * 0.5) + z * Math.cos(time * 0.5);

          const perspective = 400;
          const scale = perspective / (perspective + z);

          return {
            x: x * scale + width / 2,
            y: y * scale + height / 2,
            z: z,
            scale: scale
          };
        });

        // Draw connections
        ctx.strokeStyle = 'rgba(59, 130, 246, 0.15)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        for (let i = 0; i < projected.length; i++) {
          for (let j = i + 1; j < projected.length; j++) {
            const d = Math.hypot(projected[i].x - projected[j].x, projected[i].y - projected[j].y);
            if (d < 60) {
              ctx.moveTo(projected[i].x, projected[i].y);
              ctx.lineTo(projected[j].x, projected[j].y);
            }
          }
        }
        ctx.stroke();

        // Draw dots
        projected.forEach(p => {
          const alpha = (p.z + currentRadius) / (2 * currentRadius);
          ctx.fillStyle = `rgba(59, 130, 246, ${Math.max(0.3, alpha)})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2 * p.scale, 0, Math.PI * 2);
          ctx.fill();
        });

        animationId = requestAnimationFrame(animate);
      };

      animate();
    }
  }
</script>
