---
import { getSiteData } from '../lib/data';

const data = getSiteData();
const experience = data.experience;
---

<section id="experience" class="py-24 px-6 md:px-12 bg-slate-950/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 scroll-animate">
      <h2 class="text-blue-500 font-mono text-sm tracking-widest mb-4">// EXPERIENCE</h2>
      <h3 class="text-3xl md:text-4xl font-display font-bold text-white">CAREER TIMELINE</h3>
    </div>
    
    <!-- Alternating Timeline -->
    <div class="relative">
      <!-- Center Line (Desktop) -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-[2px] bg-gradient-to-b from-blue-500/50 via-slate-700 to-slate-800 -translate-x-1/2"></div>
      
      <!-- Experience Items -->
      <div class="space-y-6 md:space-y-0">
        {experience.map((exp, index) => {
          const isEven = index % 2 === 0;
          return (
            <div class="scroll-animate relative" style={`transition-delay: ${index * 100}ms`}>
              
              <!-- Desktop: Alternating Layout -->
              <div class="hidden md:grid md:grid-cols-[1fr_60px_1fr] items-center">
                
                {/* Left Side */}
                <div class={`${isEven ? 'pr-8' : ''}`}>
                  {isEven && (
                    <div class="group bg-slate-900/50 border border-slate-800 hover:border-blue-500/30 rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-blue-900/10 text-right">
                      <span class="font-mono text-blue-400 text-xs tracking-wider">{exp.date}</span>
                      <h3 class="text-xl font-bold text-slate-100 group-hover:text-blue-400 transition-colors mt-2">{exp.role}</h3>
                      <p class="text-slate-400 font-medium">{exp.company}</p>
                      <p class="text-slate-500 text-sm mt-3 leading-relaxed">{exp.description}</p>
                      <div class="flex flex-wrap gap-2 mt-4 justify-end">
                        {exp.tech.map((t) => (
                          <span class="px-2.5 py-1 bg-slate-800/50 border border-slate-700 rounded-full text-xs text-slate-400 font-mono">
                            {t}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
                
                {/* Center Dot */}
                <div class="flex justify-center">
                  <div class="w-4 h-4 rounded-full bg-slate-800 border-2 border-blue-500 shadow-lg shadow-blue-500/30 z-10"></div>
                </div>
                
                {/* Right Side */}
                <div class={`${!isEven ? 'pl-8' : ''}`}>
                  {!isEven && (
                    <div class="group bg-slate-900/50 border border-slate-800 hover:border-blue-500/30 rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-blue-900/10">
                      <span class="font-mono text-blue-400 text-xs tracking-wider">{exp.date}</span>
                      <h3 class="text-xl font-bold text-slate-100 group-hover:text-blue-400 transition-colors mt-2">{exp.role}</h3>
                      <p class="text-slate-400 font-medium">{exp.company}</p>
                      <p class="text-slate-500 text-sm mt-3 leading-relaxed">{exp.description}</p>
                      <div class="flex flex-wrap gap-2 mt-4">
                        {exp.tech.map((t) => (
                          <span class="px-2.5 py-1 bg-slate-800/50 border border-slate-700 rounded-full text-xs text-slate-400 font-mono">
                            {t}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
              
              <!-- Mobile: Simple Timeline -->
              <div class="md:hidden relative pl-8">
                <!-- Line -->
                <div class="absolute left-[7px] top-4 bottom-0 w-[2px] bg-slate-800"></div>
                <!-- Dot -->
                <div class="absolute left-0 top-4 w-4 h-4 rounded-full bg-slate-800 border-2 border-blue-500"></div>
                
                <div class="group bg-slate-900/50 border border-slate-800 rounded-xl p-5">
                  <span class="font-mono text-blue-400 text-xs">{exp.date}</span>
                  <h3 class="text-lg font-bold text-slate-100 mt-1">{exp.role}</h3>
                  <p class="text-slate-400 text-sm font-medium">{exp.company}</p>
                  <p class="text-slate-500 text-sm mt-2 leading-relaxed">{exp.description}</p>
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {exp.tech.map((t) => (
                      <span class="px-2 py-0.5 bg-slate-800/50 border border-slate-700 rounded-full text-xs text-slate-400 font-mono">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
              
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
