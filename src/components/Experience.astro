---
import content from '../data/content.json';
---

<section id="experience" class="py-24 px-6 md:px-12 bg-slate-950/50">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16 scroll-animate">
      <h2 class="text-blue-500 font-mono text-sm tracking-widest mb-4">// EXPERIENCE</h2>
      <h3 class="text-3xl md:text-4xl font-display font-bold text-white">CAREER TIMELINE</h3>
    </div>
    
    <div class="space-y-2">
      {content.experience.map((exp, index) => (
        <div class="scroll-animate relative pl-8 md:pl-0 group" style={`transition-delay: ${index * 100}ms`}>
          <div class="md:grid md:grid-cols-[1fr_50px_1fr] md:gap-4 items-start">
            
            <!-- Date / Left Side -->
            <div class="hidden md:block text-right pt-1 pr-6">
              <span class="font-mono text-blue-400 text-sm">{exp.date}</span>
            </div>

            <!-- Timeline Line & Dot -->
            <div class="hidden md:flex flex-col items-center h-full">
              <div class="w-3 h-3 rounded-full bg-slate-700 border border-slate-600 group-hover:bg-blue-500 group-hover:border-blue-400 group-hover:scale-125 transition-all duration-300 z-10"></div>
              {index < content.experience.length - 1 && (
                <div class="w-[1px] h-full bg-slate-800 -mt-2"></div>
              )}
            </div>

            <!-- Mobile View Line -->
            <div class="absolute left-0 top-2 bottom-0 w-[1px] bg-slate-800 md:hidden"></div>
            <div class="absolute left-[-5px] top-2 w-2.5 h-2.5 rounded-full bg-slate-700 md:hidden group-hover:bg-blue-500 transition-colors"></div>

            <!-- Content / Right Side -->
            <div class={`pb-12 ${index === content.experience.length - 1 ? 'pb-0' : ''} pl-6 md:pl-0`}>
              <div class="md:hidden font-mono text-blue-400 text-xs mb-1">{exp.date}</div>
              <h3 class="text-xl md:text-2xl font-bold text-slate-100 group-hover:text-blue-400 transition-colors">{exp.role}</h3>
              <p class="text-base md:text-lg text-slate-400 mb-2 font-medium">{exp.company}</p>
              <p class="text-slate-400 mb-4 leading-relaxed text-sm md:text-base">{exp.description}</p>
              <div class="flex flex-wrap gap-2">
                {exp.tech.map((t) => (
                  <span class="px-3 py-1 bg-slate-800/50 border border-slate-700 rounded-full text-xs text-slate-300 font-mono">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
